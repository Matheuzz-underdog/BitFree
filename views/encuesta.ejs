<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bitfree — Encuesta</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/stylesheets/shared.css" />
  <link rel="stylesheet" href="/stylesheets/encuesta.css" />
</head>

<body>

  <div class="page">

    <header>
      <nav class="navbar" aria-label="Menú principal">
        <div class="nav-left">
          <div class="nav-logo">
            <a href="/">
              <img src="/images/fondo recortado.png" alt="Bitfree logo" />
            </a>
          </div>
          <a class="nav-brand" href="/">Bitfree</a>
        </div>
        <div class="nav-items">
          <a href="/que-es-linux">¿Qué es Linux?</a>
          <a href="/encuesta" aria-current="page">Encuesta</a>
          <a href="/timeline">Distribuciones-Timeline</a>
          <button class="btn-salir">Salir</button>
        </div>
      </nav>
    </header>

    <main id="main">

      <form id="form-encuesta" novalidate>

        <div class="formulario">

          <div class="form-legend">
            <h2>Formulario de inscrición</h2>
            <p>Ingresa tus datos para la encuesta</p>
          </div>

          <div class="field-group">
            <label for="nombre">Primer nombre y apellido</label>
            <input type="text" id="nombre" name="nombre" placeholder="Jose jose" required />
          </div>

          <div class="field-group">
            <label for="edad">Edad</label>
            <input type="number" id="edad" name="edad" min="0" max="120" placeholder="25" required />
          </div>

          <div class="field-group">
            <label for="sexo">Sexo</label>
            <div class="select-wrapper">
              <select id="sexo" name="sexo">
                <option value="" disabled selected>selecciona uno</option>
                <option value="Masculino">Masculino</option>
                <option value="Femenino">Femenino</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
          </div>

          <div class="field-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" name="email" placeholder="Example@gmail.com" required />
          </div>

          <div class="field-group">
            <label for="distro">Escribe tu distribución Favorita</label>
            <input type="text" id="distro" name="distro" ="Archlinux" required />
          </div>

        </div>

        <button class="btn-enviar" type="submit">Enviar</button>

      </form>

      <section class="resultados" aria-label="Top 3 distribuciones Linux">

        <h2 class="resultados-title">Top 3 distribuciones</h2>

        <ol>
          <li>
            <span class="rank-label-1">1#</span>
            <div class="rank-box-1" id="rank-1">1</div>
          </li>
          <li>
            <span class="rank-label-2">2#</span>
            <div class="rank-box-2" id="rank-2">2</div>
          </li>
          <li>
            <span class="rank-label-3">3#</span>
            <div class="rank-box-3" id="rank-3">3</div>
          </li>
        </ol>

      </section>

    </main>

    <footer class="footer">
      <div class="footer-divider"></div>
      <div class="footer-left">
        <div class="footer-info">
          <span class="footer-made-by">Creado y Mantenido por:</span>
          <div class="footer-author-row">
            <span class="footer-author">Sergio Cuevas</span>
            <div class="footer-avatar">
              <img src="/images/291375-middle.png" alt="Sergio Cuevas" />
            </div>
          </div>
        </div>
      </div>
      <div class="footer-right">
        <div class="footer-links">
          <div class="footer-repo-row">
            <a href="https://github.com/Matheuzz-underdog/BitFree" class="footer-repo">Repositorio del Sitio</a>
            <div class="icon-github">
              <svg viewBox="0 0 24 24" fill="#B3B3B3" aria-hidden="true" focusable="false">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
          </div>
          <div class="footer-phone-row">
            <div class="footer-phone">Tlf:0800-123456789</div>
            <div class="icon-phone">
              <svg viewBox="0 0 24 24" fill="none" stroke="#B3B3B3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </footer>

  </div>

  <script src="/javascripts/encuesta-conection.js" defer></script>
</body>
</html>
